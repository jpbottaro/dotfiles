# ~/.bashrc: executed by bash(1) for non-login shells.

# If not running interactively, don't do anything
case $- in
    *i*) ;;
      *) return;;
esac

# editor
export EDITOR=nvim
export VISUAL=nvim

# path
export PATH=~/.local/bin:~/bin:$PATH

# history: drop dup/space-prefixed lines, keep it big and timestamped
HISTCONTROL=ignoreboth:erasedups
HISTSIZE=100000
HISTFILESIZE=200000
HISTTIMEFORMAT='%F %T '

# append (don't clobber) and store multi-line commands as a single entry
shopt -s histappend cmdhist

# flush each command to the history file immediately; new shells pick it up.
# append "; history -n" for live sharing across already-open tmux panes.
PROMPT_COMMAND="history -a${PROMPT_COMMAND:+; $PROMPT_COMMAND}"

# update LINES/COLUMNS after each command
shopt -s checkwinsize

# make less more friendly for non-text input files, see lesspipe(1)
[ -x /usr/bin/lesspipe ] && eval "$(SHELL=/bin/sh lesspipe)"

RED="\[\033[0;31m\]"
CYAN="\[\033[0;36m\]"
YELLOW="\[\033[0;33m\]"
GREEN="\[\033[0;32m\]"
RESET="\[\033[0m\]"

# user@host in a distinct color on the rpi boxes
if [[ $HOSTNAME == *rpi* ]]; then HOSTCOLOR="$CYAN"; else HOSTCOLOR="$RED"; fi

PS1="$HOSTCOLOR\u@\h $YELLOW\w$GREEN\$(__git_ps1) $RESET\$ "

# color support for ls and grep
if [ -x /usr/bin/dircolors ]; then
    test -r ~/.dircolors && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"
    alias ls='ls --color=auto'
    alias grep='grep --color=auto'
fi

# colored GCC warnings and errors
export GCC_COLORS='error=01;31:warning=01;35:note=01;36:caret=01;32:locus=01:quote=01'

# aliases
[ -f ~/.bash_aliases ] && . ~/.bash_aliases

# git prompt helper (path differs across distros; degrade gracefully)
for f in /usr/share/git-core/contrib/completion/git-prompt.sh \
         /usr/lib/git-core/git-sh-prompt \
         /etc/bash_completion.d/git-prompt; do
    [ -f "$f" ] && . "$f" && break
done
type __git_ps1 &>/dev/null || __git_ps1() { :; }

# fzf: fuzzy Ctrl-R history search (and Ctrl-T file finder)
if command -v fzf >/dev/null; then
    if fzf --bash >/dev/null 2>&1; then
        eval "$(fzf --bash)"                              # fzf >= 0.48
    else                                                  # older fzf: source distro files
        for f in /usr/share/fzf/shell/key-bindings.bash \
                 /usr/share/doc/fzf/examples/key-bindings.bash; do
            [ -f "$f" ] && . "$f" && break
        done
    fi
fi

# machine-specific settings (not tracked in the repo)
[ -f ~/.bashrc.local ] && . ~/.bashrc.local
