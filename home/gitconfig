[user]
	email = jpbottaro@gmail.com
	name = Juan Pablo Bottaro
[core]
	excludesfile = ~/.gitignore_global
	editor = nvim
[color]
	ui = auto
[init]
	defaultBranch = main
[push]
	default = current
	autoSetupRemote = true
[pull]
	rebase = true
[fetch]
	prune = true
[merge]
	conflictstyle = zdiff3
[rerere]
	enabled = true
[diff]
	colorMoved = default
