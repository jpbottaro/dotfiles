#!/bin/bash
# Symlink every tracked dotfile into $HOME (or ~/.config for a few).
# Idempotent: skips links that are already correct, only backs up real files.

cd "$(dirname "$0")/.." || exit 1

skip='README scripts CLAUDE.md misc'

for name in *; do
    [[ " $skip " == *" $name "* ]] && continue

    if [[ $name == 'gtk-3.0' || $name == 'nvim' ]]; then
        mkdir -p ~/.config
        target="$HOME/.config/$name"
    else
        target="$HOME/.$name"
    fi

    # already linked to the right place -> nothing to do
    [[ "$(readlink -f "$target")" == "$PWD/$name" ]] && continue

    # back up a real file/dir (not a symlink) before replacing it
    [[ -e $target && ! -h $target ]] && mv "$target" "$target.bk"

    ln -sfn "$PWD/$name" "$target"
    echo "linked $target"
done
